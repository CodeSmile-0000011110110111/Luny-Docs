{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "Library/XmlDocs/Luny*.dll"
          ],
          "exclude": [
          ],
          "src": "../../.."
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "disableGitFeatures": true,
      "disableDefaultFilter": false,
      "filter": "filterConfig.yml",
      "properties": {
        "AllowUnsafeBlocks": "true",
        "LangVersion": "9.0"
      }
    }
  ],
  "build": {
    "incremental": false,
    "xref": [
      "https://normanderwan.github.io/UnityXrefMaps/xrefmap.yml"
    ],
    "sitemap": {
      "baseUrl": "https://lunyscript.com/documentation",
      "changefreq": "daily"
    },
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "api-index.md"
        ]
      },
      {
        "files": [
          "index.md",
          "*.yml"
        ],
        "src": "api",
        "dest": "api"
      }
    ],
    "resource": [
      {
        "files": ["images/**"],
        "src": "."
      },
      {
        "files": ["styles/**"],
        "src": "."
      }
    ],
    "output": "../../../docfx-output",
    "template": [
      "default",
      "modern",
      "templates/modern"
    ],
    "globalMetadata": {
      "_appTitle": "LunyScript Documentation",
      "_appName": "Script",
      "_appFooter": "© 2025-2026 Steffen Itterheim (CodeSmile)",
      "_enableSearch": true,
      "_appLogoPath": "images/Luny-logo-133x54.png",
      "_appFaviconPath": "images/luny-logo-56x56.png",
      "_googleAnalyticsTagId": "",
      "_lang": "en",
      "_appLogoUrl": "/",
      "_extraCss": [
        "styles/main.css",
        "styles/alert.css"
      ]
    },
    "fileMetadata": {},
    "markdownEngineProperties": {
      "markdigExtensions": [
        "attributes",
        "customcontainers",
        "Abbreviations",
        "Footnotes"
      ],
      "alerts": {
        "TIP": "alert alert-tip"
      }
    }
  },
  "rules": {
    "InvalidAssemblyReference": "warning"
  }
}
